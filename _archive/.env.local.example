# ═══════════════════════════════════════════════════
# Mizanet — ÇEVRE DEĞİŞKENLERİ
# Bu dosyayı .env.local olarak kaydedin
# ASLA git'e commit etmeyin — .gitignore'da olmalı
# ═══════════════════════════════════════════════════

# ─── SUPABASE (Zorunlu) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://cauptlsnqieegdrgotob.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=BURAYA_SUPABASE_ANON_KEY_YAZIN

# Sunucu taraflı API'ler için (Webhook, Ajan Çalıştırıcı)
# Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=BURAYA_SERVICE_ROLE_KEY_YAZIN

# ─── GÜVENLİK (Zorunlu) ───────────────────────────
# Yönetici silme/değiştirme PIN kodu
NEXT_PUBLIC_ADMIN_PIN=BURAYA_GUVENLI_BIR_PIN_YAZIN

# ─── TELEGRAM BOT (Zorunlu) ───────────────────────
# BotFather'dan alınan token
TELEGRAM_BOT_TOKEN=BURAYA_BOT_TOKEN_YAZIN
# Telegram chat ID (patronun kişisel chat ID'si)
TELEGRAM_CHAT_ID=BURAYA_CHAT_ID_YAZIN

# ─── AI API'LERİ (Opsiyonel) ──────────────────────
# Perplexity (Ar-Ge trend analizi için)
PERPLEXITY_API_KEY=BURAYA_PERPLEXITY_KEY_YAZIN

# Google Gemini (Denetmen AI Vision için)
GOOGLE_GEMINI_API_KEY=BURAYA_GEMINI_KEY_YAZIN

# ─── ÜRETIM PARAMETRELERİ (Opsiyonel) ─────────────
# Dakika başı ortalama ücret (Ayarlar sayfasından override edilebilir)
NEXT_PUBLIC_DAKIKA_UCRETI=2.50
